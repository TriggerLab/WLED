{
  "$schema": "https://docs.renovatebot.com",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)platformio\\.ini$", "(^|/)platformio_override\\.ini$"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/\\s#]+?)(?:\\.git)?#(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)platformio\\.ini$", "(^|/)platformio_override\\.ini$"],
      "matchStrings": [
        "(?<depName>ArduinoJson|ESPAsyncWebServer|FastLED|NeoPixelBus|OneWire)@(?<currentValue>[\\d\\.]+)"
      ],
      "datasourceTemplate": "platformio"
    }
  ]
}
